##
## HyperKRW DEX Server — Environment Variables (O-6)
## Copy: cp .env.example .env   |   NEVER commit .env
##

# ── Chain ─────────────────────────────────────────────────────────────────────
# Testnet: CHAIN_ID=998  |  Mainnet: CHAIN_ID=999
RPC_URL=https://rpc.hyperliquid-testnet.xyz/evm
CHAIN_ID=998

# O-4: Secondary RPC for viem fallback transport (optional, recommended)
# RPC_URL_FALLBACK=https://hyperevm.g.alchemy.com/v2/YOUR_KEY

# ── Operator ──────────────────────────────────────────────────────────────────
# Signs settlement transactions on-chain. Phase R: replace with Vault/HSM.
OPERATOR_PRIVATE_KEY=0x...

# ── Contract Addresses ────────────────────────────────────────────────────────
# Fill in after: forge script script/DeployTestnet.s.sol --broadcast
ORDER_SETTLEMENT_ADDRESS=0x...
PAIR_REGISTRY_ADDRESS=0x...
ORACLE_ADMIN_ADDRESS=0x...

# ── API Auth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
ADMIN_API_KEY=change-me-in-production

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
BATCH_TIMEOUT_MS=1000
BATCH_SIZE=10
BLOCKED_COUNTRIES=KP,IR,SY,CU

# ── O-1: PostgreSQL Persistence (optional) ────────────────────────────────────
# Server runs in-memory only if not set (data lost on restart).
DATABASE_URL=postgresql://krwdex:secret@localhost:5432/krwdex

# ── O-2: Redis Pub/Sub (optional) ────────────────────────────────────────────
# Uses in-process EventEmitter (single-instance) if not set.
REDIS_URL=redis://localhost:6379

# ── O-7: OFAC / Chainalysis Screening (optional) ─────────────────────────────
# Enables Layer-2 Chainalysis risk scoring on top of local SDN list.
# CHAINALYSIS_API_KEY=

# ── R-2: HashiCorp Vault (optional — leave blank for testnet/dev) ──────────
# When set, OPERATOR_PRIVATE_KEY is ignored — key is read from Vault KV v2
VAULT_ADDR=
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# ── O-3: Ponder Indexer (optional, separate service) ─────────────────────────
# Required for indexer service in docker-compose.yml
# InsuranceFund address — needed by indexer (not by krw-dex-server itself)
INSURANCE_FUND_ADDRESS=0x...
# Deployment start block (find in: krw-dex-contracts/broadcast/.../run-latest.json)
START_BLOCK=0

# ── R-7: Circuit Breaker (optional) ──────────────────────────────────────────
# Auto-halts trading when mark price moves > PRICE_BAND_PCT% within WINDOW_MS.
# Admin can also manually halt/resume via POST /admin/halt and /admin/resume.
CIRCUIT_BREAKER_PRICE_BAND_PCT=10
CIRCUIT_BREAKER_WINDOW_MS=60000

# ── Rate Limiting: Per-Wallet ─────────────────────────────────────────────────
# Max orders per wallet per window. Protects against spam.
WALLET_RATE_LIMIT_MAX=10
WALLET_RATE_LIMIT_WINDOW_MS=1000

# ── Chain: Funding Reserve (optional) ────────────────────────────────────────
# When set, off-chain funding payments are settled on-chain via settleFunding().
# Typically the InsuranceFund or a reserve contract address.
# FUNDING_RESERVE_ADDRESS=0x...

# ── Traefik / Docker Compose ──────────────────────────────────────────────────
API_DOMAIN=api.hyperkrw.xyz
ACME_EMAIL=admin@hyperkrw.xyz
POSTGRES_PASSWORD=secret
