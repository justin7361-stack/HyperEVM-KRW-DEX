##
## HyperKRW Contracts — Testnet Deployment Env (Q-2)
## Copy: cp .env.testnet.example .env.testnet
##       source .env.testnet
## NEVER commit .env.testnet
##

# ── Deployer ─────────────────────────────────────────────────────────────────
# Has HYPE testnet tokens (faucet: https://faucet.hyperliquid-testnet.xyz)
# Becomes DEFAULT_ADMIN_ROLE. Transfer to Gnosis Safe after Config.s.sol.
DEPLOYER_PRIVATE_KEY=0x...

# ── Role Wallets ─────────────────────────────────────────────────────────────
# Operator = krw-dex-server wallet (gets OPERATOR_ROLE on settlement/oracle/registry)
OPERATOR_ADDRESS=0x...
# Guardian = cold wallet for emergency pause only (cannot unpause — by design)
GUARDIAN_ADDRESS=0x...

# ── Admin key (same as deployer for testnet, separate for mainnet) ─────────
ADMIN_ADDRESS=            # can leave blank — DeployTestnet uses deployer as admin
ADMIN_PRIVATE_KEY=        # only needed if running separate Config.s.sol

# ── Optional: bring your own tokens (leave blank to auto-deploy mocks) ───────
# KRW_STABLECOIN_ADDRESS=0x...   # real KRW stablecoin (skip MockKRW deploy)
# USDC_ADDRESS=0x...             # testnet USDC (skip MockUSDC deploy)

# ── RPC / Explorer ───────────────────────────────────────────────────────────
HYPEREVM_TESTNET_RPC=https://rpc.hyperliquid-testnet.xyz/evm
HYPEREVM_TESTNET_EXPLORER=https://explorer.hyperliquid-testnet.xyz

# Block explorer API key (if verification supported — check testnet explorer docs)
# ETHERSCAN_API_KEY=

# ── Deployed Addresses (fill in AFTER running DeployTestnet.s.sol) ───────────
# These are printed by the script as "=== .env COPY-PASTE ==="
ORDER_SETTLEMENT_ADDRESS=
PAIR_REGISTRY_ADDRESS=
ORACLE_ADMIN_ADDRESS=
INSURANCE_FUND_ADDRESS=
MARGIN_REGISTRY_ADDRESS=
FEE_COLLECTOR_ADDRESS=
